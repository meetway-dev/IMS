generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String                 @id @default(uuid()) @db.Uuid
  email                    String                 @unique
  passwordHash             String?
  googleSubject            String?                @unique
  name                     String?
  status                   UserStatus             @default(ACTIVE)
  isEmailVerified          Boolean                @default(false)
  lastLoginAt              DateTime?
  lastPasswordChangeAt     DateTime?
  failedLoginAttempts      Int                    @default(0)
  lockedUntil              DateTime?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  deletedAt                DateTime?
  archivedAt               DateTime?
  auditLogs                AuditLog[]             @relation("AuditActorUser")
  inventoryTransactions    InventoryTransaction[]
  orders                   Order[]
  passwordResets           PasswordResetToken[]
  refreshTokens            RefreshToken[]
  createdRoles             Role[]                 @relation("RoleCreator")
  assignedRolePermissions  RolePermission[]       @relation("RolePermissionAssigner")
  assignedUserPermissions  UserPermission[]       @relation("UserPermissionAssigner")
  directPermissions        UserPermission[]
  assignedUserRoles        UserRole[]             @relation("UserRoleAssigner")
  roles                    UserRole[]
  managedWarehouses        Warehouse[]            @relation("WarehouseManager")
  createdPurchaseOrders    PurchaseOrder[]        @relation("PurchaseOrderCreator")
  approvedPurchaseOrders   PurchaseOrder[]        @relation("PurchaseOrderApprover")
  createdGoodsReceiptNotes GoodsReceiptNote[]

  @@index([status])
  @@index([deletedAt])
  @@index([email])
  @@index([lastLoginAt])
  @@index([createdAt])
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  name            String           @unique
  description     String?
  isSystem        Boolean          @default(false)
  isDefault       Boolean          @default(false)
  priority        Int              @default(0)
  parentRoleId    String?          @db.Uuid
  createdByUserId String?          @db.Uuid
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  createdByUser   User?            @relation("RoleCreator", fields: [createdByUserId], references: [id])
  parentRole      Role?            @relation("RoleHierarchy", fields: [parentRoleId], references: [id])
  childRoles      Role[]           @relation("RoleHierarchy")
  permissions     RolePermission[]
  users           UserRole[]

  @@index([deletedAt])
  @@index([isSystem])
  @@index([isDefault])
  @@index([priority])
  @@index([parentRoleId])
  @@index([name])
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  key             String           @unique
  name            String
  description     String?
  type            PermissionType   @default(CRUD)
  effect          PermissionEffect @default(ALLOW)
  module          String
  resource        String?
  action          String?
  scope           String?
  isSystem        Boolean          @default(false)
  version         Int              @default(1)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  roles           RolePermission[]
  userPermissions UserPermission[]

  @@unique([resource, action, scope])
  @@index([deletedAt])
  @@index([module])
  @@index([resource])
  @@index([action])
  @@index([type])
  @@index([key])
}

model UserRole {
  userId           String    @db.Uuid
  roleId           String    @db.Uuid
  assignedByUserId String?   @db.Uuid
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  assignedByUser   User?     @relation("UserRoleAssigner", fields: [assignedByUserId], references: [id])
  role             Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@index([userId])
  @@index([expiresAt])
}

model RolePermission {
  roleId           String     @db.Uuid
  permissionId     String     @db.Uuid
  assignedByUserId String?    @db.Uuid
  expiresAt        DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  assignedByUser   User?      @relation("RolePermissionAssigner", fields: [assignedByUserId], references: [id])
  permission       Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role             Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@index([roleId])
  @@index([expiresAt])
}

model UserPermission {
  userId           String           @db.Uuid
  permissionId     String           @db.Uuid
  priority         Int              @default(0)
  effect           PermissionEffect @default(ALLOW)
  assignedByUserId String?          @db.Uuid
  reason           String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  expiresAt        DateTime?
  assignedByUser   User?            @relation("UserPermissionAssigner", fields: [assignedByUserId], references: [id])
  permission       Permission       @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@index([permissionId])
  @@index([userId])
  @@index([priority])
  @@index([expiresAt])
  @@index([effect])
}

model AuditLog {
  id          String         @id @default(uuid()) @db.Uuid
  actorType   AuditActorType @default(USER)
  actorUserId String?        @db.Uuid
  action      AuditAction
  entityType  String?
  entityId    String?
  ip          String?
  userAgent   String?
  metadata    Json?
  requestId   String?        @unique
  endpoint    String?
  method      String?
  statusCode  Int?
  createdAt   DateTime       @default(now())
  actorUser   User?          @relation("AuditActorUser", fields: [actorUserId], references: [id])

  @@index([actorType, createdAt])
  @@index([actorUserId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([requestId])
}

model Company {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  code        String?   @unique
  email       String?
  phone       String?
  address     String?
  taxId       String?
  website     String?
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  products    Product[]

  @@index([deletedAt])
  @@index([isActive])
  @@index([email])
}

model Category {
  id          String     @id @default(uuid()) @db.Uuid
  name        String
  slug        String
  parentId    String?    @db.Uuid
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  description String?
  parent      Category?  @relation("CategoryToChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryToChildren")
  products    Product[]

  @@unique([parentId, slug])
  @@index([parentId])
  @@index([deletedAt])
}

model Supplier {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  email          String?         @unique
  phone          String?
  address        String?
  contactPerson  String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  purchaseOrders PurchaseOrder[]

  @@index([deletedAt])
}

model Product {
  id            String           @id @default(uuid()) @db.Uuid
  name          String
  sku           String           @unique
  barcode       String?          @unique
  typeId        String           @db.Uuid
  unitId        String           @db.Uuid
  purchasePrice Decimal          @db.Decimal(12, 2)
  salePrice     Decimal          @db.Decimal(12, 2)
  minStockAlert Int              @default(0)
  categoryId    String?          @db.Uuid
  companyId     String?          @db.Uuid
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?
  inventory     InventoryItem?
  orderItems    OrderItem[]
  type          ProductType      @relation(fields: [typeId], references: [id], onDelete: Restrict)
  unit          UnitOfMeasure    @relation(fields: [unitId], references: [id], onDelete: Restrict)
  category      Category?        @relation(fields: [categoryId], references: [id])
  company       Company?         @relation(fields: [companyId], references: [id])
  variants      ProductVariant[]

  @@index([categoryId])
  @@index([companyId])
  @@index([deletedAt])
  @@index([typeId])
  @@index([unitId])
}

model ProductVariant {
  id                 String              @id @default(uuid()) @db.Uuid
  productId          String              @db.Uuid
  size               String?
  color              String?
  material           String?
  sku                String?             @unique
  barcode            String?             @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  inventory          InventoryItem?
  orderItems         OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([deletedAt])
}

model InventoryItem {
  id                String                 @id @default(uuid()) @db.Uuid
  productId         String?                @unique @db.Uuid
  variantId         String?                @unique @db.Uuid
  stockQuantity     Int                    @default(0)
  reservedQuantity  Int                    @default(0)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  deletedAt         DateTime?
  product           Product?               @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant           ProductVariant?        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  transactions      InventoryTransaction[]
  stockLevels       StockLevel[]
  purchaseOrders    PurchaseOrder[]
  goodsReceiptNotes GoodsReceiptNote[]

  @@index([deletedAt])
}

model InventoryTransaction {
  id              String                   @id @default(uuid()) @db.Uuid
  inventoryItemId String                   @db.Uuid
  type            InventoryTransactionType
  quantityDelta   Int
  reference       String?
  note            String?
  createdByUserId String?                  @db.Uuid
  createdAt       DateTime                 @default(now())
  createdByUser   User?                    @relation(fields: [createdByUserId], references: [id])
  inventoryItem   InventoryItem            @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId, createdAt])
  @@index([type])
  @@index([createdByUserId])
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  orderNumber     String      @unique
  status          OrderStatus @default(DRAFT)
  subtotal        Decimal     @db.Decimal(12, 2)
  discountTotal   Decimal     @default(0) @db.Decimal(12, 2)
  taxTotal        Decimal     @default(0) @db.Decimal(12, 2)
  total           Decimal     @db.Decimal(12, 2)
  notes           String?
  createdByUserId String?     @db.Uuid
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?
  createdByUser   User?       @relation(fields: [createdByUserId], references: [id])
  items           OrderItem[]

  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
}

model OrderItem {
  id        String          @id @default(uuid()) @db.Uuid
  orderId   String          @db.Uuid
  productId String?         @db.Uuid
  variantId String?         @db.Uuid
  quantity  Int
  unitPrice Decimal         @db.Decimal(12, 2)
  lineTotal Decimal         @db.Decimal(12, 2)
  createdAt DateTime        @default(now())
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product?        @relation(fields: [productId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model RefreshToken {
  id           String         @id @default(uuid()) @db.Uuid
  userId       String         @db.Uuid
  tokenHash    String
  sessionId    String
  userAgent    String?
  ip           String?
  revokedAt    DateTime?
  replacedById String?        @db.Uuid
  expiresAt    DateTime
  createdAt    DateTime       @default(now())
  replacedBy   RefreshToken?  @relation("RefreshTokenRotation", fields: [replacedById], references: [id])
  replaces     RefreshToken[] @relation("RefreshTokenRotation")
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sessionId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
  PENDING
}

enum PermissionType {
  CRUD
  PAGE
  ACTION
  RESOURCE
  SYSTEM
}

enum PermissionEffect {
  ALLOW
  DENY
}

enum AuditAction {
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  USER_ROLE_ASSIGNED
  USER_ROLE_REVOKED
  USER_PERMISSION_ASSIGNED
  USER_PERMISSION_REVOKED
  USER_LOGIN
  USER_LOGOUT
  USER_PASSWORD_CHANGED
  ROLE_CREATED
  ROLE_UPDATED
  ROLE_DELETED
  ROLE_PERMISSION_ASSIGNED
  ROLE_PERMISSION_REVOKED
  ROLE_CLONED
  PERMISSION_CREATED
  PERMISSION_UPDATED
  PERMISSION_DELETED
  SETTINGS_UPDATED
  AUDIT_LOG_VIEWED
  SYSTEM_BACKUP
  SYSTEM_RESTORE
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_DELETED
  ORDER_CREATED
  ORDER_UPDATED
  ORDER_DELETED
  INVENTORY_ADJUSTED
  API_REQUEST
  ORDER_CONFIRMED
  ORDER_PAID
  ORDER_CANCELLED
  CATEGORY_CREATED
  CATEGORY_UPDATED
  CATEGORY_DELETED
  SUPPLIER_CREATED
  SUPPLIER_UPDATED
  SUPPLIER_DELETED
  COMPANY_CREATED
  COMPANY_UPDATED
  COMPANY_DELETED
  UNIT_OF_MEASURE_CREATED
  UNIT_OF_MEASURE_UPDATED
  UNIT_OF_MEASURE_DELETED
  PRODUCT_TYPE_CREATED
  PRODUCT_TYPE_UPDATED
  PRODUCT_TYPE_DELETED
}

enum AuditActorType {
  USER
  SYSTEM
  API
  BATCH
}

enum InventoryTransactionType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  PAID
  CANCELLED
  REFUNDED
}

model ProductType {
  id             String          @id @default(uuid()) @db.Uuid
  name           String          @unique
  slug           String          @unique
  description    String?
  isActive       Boolean         @default(true)
  products       Product[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  purchaseOrders PurchaseOrder[]

  @@index([deletedAt])
  @@index([isActive])
  @@index([slug])
}

model UnitOfMeasure {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  slug        String    @unique
  symbol      String?
  description String?
  isActive    Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([deletedAt])
  @@index([isActive])
  @@index([slug])
}

enum WarehouseType {
  MAIN
  DISTRIBUTION
  RETAIL
  COLD_STORAGE
  BONDED
}

model Warehouse {
  id                String             @id @default(uuid()) @db.Uuid
  name              String             @unique
  code              String?            @unique
  type              WarehouseType      @default(MAIN)
  address           String?
  city              String?
  state             String?
  country           String?
  postalCode        String?
  phone             String?
  email             String?
  managerId         String?            @db.Uuid
  isActive          Boolean            @default(true)
  capacity          Int?
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  manager           User?              @relation("WarehouseManager", fields: [managerId], references: [id])
  locations         Location[]
  stockLevels       StockLevel[]
  purchaseOrders    PurchaseOrder[]
  goodsReceiptNotes GoodsReceiptNote[]

  @@index([deletedAt])
  @@index([isActive])
  @@index([type])
  @@index([managerId])
}

enum LocationType {
  SHELF
  BIN
  PALLET
  RACK
  FLOOR
  COLD_ROOM
}

model Location {
  id          String       @id @default(uuid()) @db.Uuid
  warehouseId String       @db.Uuid
  name        String
  code        String       @unique
  type        LocationType @default(SHELF)
  aisle       String?
  row         String?
  section     String?
  level       String?
  position    String?
  capacity    Int?
  isActive    Boolean      @default(true)
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  stockLevels StockLevel[]

  @@unique([warehouseId, code])
  @@index([deletedAt])
  @@index([warehouseId])
  @@index([isActive])
  @@index([type])
}

model StockLevel {
  id              String        @id @default(uuid()) @db.Uuid
  inventoryItemId String        @db.Uuid
  warehouseId     String        @db.Uuid
  locationId      String?       @db.Uuid
  quantity        Int           @default(0)
  reserved        Int           @default(0)
  minQuantity     Int           @default(0)
  maxQuantity     Int?
  reorderPoint    Int?
  lastCountedAt   DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  warehouse       Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  location        Location?     @relation(fields: [locationId], references: [id])

  @@unique([inventoryItemId, warehouseId, locationId])
  @@index([deletedAt])
  @@index([inventoryItemId])
  @@index([warehouseId])
  @@index([locationId])
  @@index([quantity])
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PARTIALLY_RECEIVED
  COMPLETED
  CANCELLED
}

enum PurchaseOrderItemStatus {
  PENDING
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id                   String              @id @default(uuid()) @db.Uuid
  poNumber             String              @unique
  supplierId           String              @db.Uuid
  warehouseId          String              @db.Uuid
  status               PurchaseOrderStatus @default(DRAFT)
  expectedDeliveryDate DateTime?
  totalAmount          Decimal             @db.Decimal(12, 2)
  notes                String?
  createdByUserId      String?             @db.Uuid
  approvedByUserId     String?             @db.Uuid
  approvedAt           DateTime?
  completedAt          DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  deletedAt            DateTime?
  createdByUser        User?               @relation("PurchaseOrderCreator", fields: [createdByUserId], references: [id])
  approvedByUser       User?               @relation("PurchaseOrderApprover", fields: [approvedByUserId], references: [id])
  supplier             Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  warehouse            Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  items                PurchaseOrderItem[]
  receipts             GoodsReceiptNote[]
  inventoryItem        InventoryItem?      @relation(fields: [inventoryItemId], references: [id])
  inventoryItemId      String?             @db.Uuid
  productType          ProductType?        @relation(fields: [productTypeId], references: [id])
  productTypeId        String?             @db.Uuid

  @@index([deletedAt])
  @@index([status])
  @@index([supplierId])
  @@index([warehouseId])
  @@index([createdAt])
  @@index([poNumber])
}

model PurchaseOrderItem {
  id                String                  @id @default(uuid()) @db.Uuid
  purchaseOrderId   String                  @db.Uuid
  variantId         String                  @db.Uuid
  quantity          Int
  unitPrice         Decimal                 @db.Decimal(12, 2)
  lineTotal         Decimal                 @db.Decimal(12, 2)
  status            PurchaseOrderItemStatus @default(PENDING)
  receivedQuantity  Int                     @default(0)
  notes             String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  deletedAt         DateTime?
  purchaseOrder     PurchaseOrder           @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  variant           ProductVariant          @relation(fields: [variantId], references: [id], onDelete: Restrict)
  goodsReceiptItems GoodsReceiptItem[]

  @@index([deletedAt])
  @@index([purchaseOrderId])
  @@index([variantId])
  @@index([status])
}

enum GoodsReceiptStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

model GoodsReceiptNote {
  id              String             @id @default(uuid()) @db.Uuid
  grnNumber       String             @unique
  purchaseOrderId String             @db.Uuid
  warehouseId     String             @db.Uuid
  status          GoodsReceiptStatus @default(DRAFT)
  receiptDate     DateTime           @default(now())
  notes           String?
  createdByUserId String?            @db.Uuid
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?
  createdByUser   User?              @relation(fields: [createdByUserId], references: [id])
  purchaseOrder   PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  warehouse       Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  items           GoodsReceiptItem[]
  inventoryItem   InventoryItem?     @relation(fields: [inventoryItemId], references: [id])
  inventoryItemId String?            @db.Uuid

  @@index([deletedAt])
  @@index([purchaseOrderId])
  @@index([warehouseId])
  @@index([grnNumber])
  @@index([receiptDate])
}

model GoodsReceiptItem {
  id                  String            @id @default(uuid()) @db.Uuid
  goodsReceiptNoteId  String            @db.Uuid
  purchaseOrderItemId String            @db.Uuid
  quantity            Int
  unitPrice           Decimal           @db.Decimal(12, 2)
  lineTotal           Decimal           @db.Decimal(12, 2)
  batchNumber         String?
  expiryDate          DateTime?
  notes               String?
  createdAt           DateTime          @default(now())
  goodsReceiptNote    GoodsReceiptNote  @relation(fields: [goodsReceiptNoteId], references: [id], onDelete: Cascade)
  purchaseOrderItem   PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id], onDelete: Restrict)

  @@index([goodsReceiptNoteId])
  @@index([purchaseOrderItemId])
  @@index([batchNumber])
}
