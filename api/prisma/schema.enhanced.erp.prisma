// ==============================================
// ENHANCED ERP INVENTORY MANAGEMENT SCHEMA
// ==============================================
// Professional, scalable inventory system with:
// 1. Product Variants with attribute system
// 2. SKU generation system
// 3. Units of measurement with conversions
// 4. Multi-warehouse inventory
// 5. Batch/lot tracking
// 6. Comprehensive inventory transactions
// 7. Stock movement ledger

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==============================================
// ENHANCED ENUMS
// ==============================================

// Keep existing enums and add new ones
enum UserStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
  PENDING
}

enum PermissionType {
  CRUD
  PAGE
  ACTION
  RESOURCE
  SYSTEM
}

enum PermissionEffect {
  ALLOW
  DENY
}

enum AuditAction {
  // Keep existing audit actions
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  USER_ROLE_ASSIGNED
  USER_ROLE_REVOKED
  USER_PERMISSION_ASSIGNED
  USER_PERMISSION_REVOKED
  USER_LOGIN
  USER_LOGOUT
  USER_PASSWORD_CHANGED
  
  ROLE_CREATED
  ROLE_UPDATED
  ROLE_DELETED
  ROLE_PERMISSION_ASSIGNED
  ROLE_PERMISSION_REVOKED
  ROLE_CLONED
  
  PERMISSION_CREATED
  PERMISSION_UPDATED
  PERMISSION_DELETED
  
  SETTINGS_UPDATED
  AUDIT_LOG_VIEWED
  SYSTEM_BACKUP
  SYSTEM_RESTORE
  API_REQUEST
  
  // Enhanced inventory actions
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_DELETED
  PRODUCT_VARIANT_CREATED
  PRODUCT_VARIANT_UPDATED
  PRODUCT_VARIANT_DELETED
  
  INVENTORY_PURCHASE
  INVENTORY_SALE
  INVENTORY_ADJUSTMENT
  INVENTORY_TRANSFER
  INVENTORY_RETURN
  INVENTORY_WRITE_OFF
  
  WAREHOUSE_CREATED
  WAREHOUSE_UPDATED
  WAREHOUSE_DELETED
  
  BATCH_CREATED
  BATCH_UPDATED
  BATCH_EXPIRED
  
  ORDER_CREATED
  ORDER_UPDATED
  ORDER_DELETED
  ORDER_CONFIRMED
  ORDER_PAID
  ORDER_CANCELLED
  
  CATEGORY_CREATED
  CATEGORY_UPDATED
  CATEGORY_DELETED
  SUPPLIER_CREATED
  SUPPLIER_UPDATED
  SUPPLIER_DELETED
  COMPANY_CREATED
  COMPANY_UPDATED
  COMPANY_DELETED
}

enum AuditActorType {
  USER
  SYSTEM
  API
  BATCH
}

// Enhanced inventory enums
enum ProductType {
  SANITARY
  ELECTRICAL
  PLUMBING
  HARDWARE
  CONSUMABLE
  RAW_MATERIAL
  FINISHED_GOOD
}

enum UnitOfMeasure {
  PIECE
  BOX
  METER
  KILOGRAM
  LITER
  ROLL
  SET
  PACK
  CASE
  PALLET
}

enum InventoryTransactionType {
  PURCHASE
  SALE
  ADJUSTMENT
  TRANSFER
  RETURN
  WRITE_OFF
  PRODUCTION_IN
  PRODUCTION_OUT
  CONSUMPTION
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  PROCESSING
  PACKED
  SHIPPED
  DELIVERED
  PAID
  CANCELLED
  REFUNDED
  ON_HOLD
}

enum WarehouseType {
  MAIN
  BRANCH
  STORE
  VIRTUAL
  TRANSIT
  QUARANTINE
}

enum BatchStatus {
  ACTIVE
  EXPIRED
  CONSUMED
  QUARANTINED
  RECALLED
}

// ==============================================
// CORE RBAC MODELS (Keep existing)
// ==============================================

model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String     @unique
  passwordHash    String?
  googleSubject   String?    @unique
  name            String?
  status          UserStatus @default(ACTIVE)
  isEmailVerified Boolean    @default(false)
  lastLoginAt     DateTime?
  lastPasswordChangeAt DateTime?
  failedLoginAttempts Int    @default(0)
  lockedUntil     DateTime?

  // RBAC relationships
  roles           UserRole[]
  directPermissions UserPermission[]

  // RBAC assignment relationships
  createdRoles    Role[]              @relation("RoleCreator")
  assignedUserRoles UserRole[]        @relation("UserRoleAssigner")
  assignedRolePermissions RolePermission[] @relation("RolePermissionAssigner")
  assignedUserPermissions UserPermission[] @relation("UserPermissionAssigner")

  // Authentication
  refreshTokens   RefreshToken[]
  passwordResets  PasswordResetToken[]

  // Audit
  auditLogs       AuditLog[]           @relation("AuditActorUser")

  // Business relationships
  inventoryTransactions InventoryTransaction[]
  orders                Order[]
  stockMovements        StockMovement[]

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  archivedAt      DateTime?

  // Indexes
  @@index([status])
  @@index([deletedAt])
  @@index([email])
  @@index([lastLoginAt])
  @@index([createdAt])
}

model Role {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique
  description String?
  isSystem    Boolean @default(false)
  isDefault   Boolean @default(false)
  priority    Int     @default(0)
  parentRoleId String? @db.Uuid
  
  // Relationships
  users       UserRole[]
  permissions RolePermission[]
  parentRole  Role?    @relation("RoleHierarchy", fields: [parentRoleId], references: [id], onDelete: SetNull)
  childRoles  Role[]   @relation("RoleHierarchy")
  
  // Metadata
  createdByUserId String? @db.Uuid
  createdByUser   User?   @relation("RoleCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  
  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Indexes
  @@index([deletedAt])
  @@index([isSystem])
  @@index([isDefault])
  @@index([priority])
  @@index([parentRoleId])
  @@index([name])
}

model Permission {
  id          String         @id @default(uuid()) @db.Uuid
  key         String         @unique
  name        String
  description String?
  type        PermissionType @default(CRUD)
  effect      PermissionEffect @default(ALLOW)
  module      String
  resource    String?
  action      String?
  scope       String?
  
  // Relationships
  roles       RolePermission[]
  userPermissions UserPermission[]
  
  // Metadata
  isSystem    Boolean @default(false)
  version     Int     @default(1)
  
  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Constraints and Indexes
  @@unique([resource, action, scope])
  @@index([deletedAt])
  @@index([module])
  @@index([resource])
  @@index([action])
  @@index([type])
  @@index([key])
}

// Junction tables (keep existing)
model UserRole {
  userId String @db.Uuid
  roleId String @db.Uuid
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  assignedByUserId String? @db.Uuid
  assignedByUser   User?   @relation("UserRoleAssigner", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  expiresAt        DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@id([userId, roleId])
  @@index([roleId])
  @@index([userId])
  @@index([expiresAt])
}

model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid
  
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  assignedByUserId String? @db.Uuid
  assignedByUser   User?   @relation("RolePermissionAssigner", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  expiresAt        DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@id([roleId, permissionId])
  @@index([permissionId])
  @@index([roleId])
  @@index([expiresAt])
}

model UserPermission {
  userId       String @db.Uuid
  permissionId String @db.Uuid
  priority     Int    @default(0)
  effect       PermissionEffect @default(ALLOW)
  
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  assignedByUserId String? @db.Uuid
  assignedByUser   User?   @relation("UserPermissionAssigner", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  reason           String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime?
  
  @@id([userId, permissionId])
  @@index([permissionId])
  @@index([userId])
  @@index([priority])
  @@index([expiresAt])
  @@index([effect])
}

// ==============================================
// ENHANCED INVENTORY MODELS
// ==============================================

// 1. PRODUCT ATTRIBUTE SYSTEM
model ProductAttribute {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique  // e.g., "Size", "Color", "Material", "Brand"
  code        String  @unique  // e.g., "SIZE", "COLOR", "MATERIAL"
  description String?
  dataType    String  @default("STRING") // STRING, NUMBER, BOOLEAN
  isRequired  Boolean @default(false)
  isVariant   Boolean @default(true) // Whether this attribute creates variants
  sortOrder   Int     @default(0)
  
  // Relationships
  attributeValues ProductAttributeValue[]
  variantAttributes ProductVariantAttribute[]
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  
  @@index([code])
  @@index([isVariant])
  @@index([deletedAt])
}

model ProductAttributeValue {
  id         String  @id @default(uuid()) @db.Uuid
  attributeId String @db.Uuid
  value      String  // e.g., "Red", "3 inch", "PVC"
  code       String? // e.g., "RED", "3IN", "PVC"
  sortOrder  Int     @default(0)
  
  // Relationships
  attribute ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  variantAttributes ProductVariantAttribute[]
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  
  @@unique([attributeId, value])
  @@index([attributeId])
  @@index([code])
  @@index([deletedAt])
}

// 2. PRODUCT CATALOG
model Product {
  id            String        @id @default(uuid()) @db.Uuid
  name          String
  description   String?
  baseSku       String        @unique // Base SKU for the product family
  type          ProductType
  categoryId    String?       @db.Uuid
  companyId     String?       @db.Uuid
  supplierId    String?       @db.Uuid
  
  // Pricing
  costPrice     Decimal       @db.Decimal(12, 2) @default(0)
  retailPrice   Decimal       @db.Decimal(12, 2) @default(0)
  wholesalePrice Decimal?     @db.Decimal(12, 2)
  
  // Inventory settings
  minStockLevel Int           @default(0)
  maxStockLevel Int?
  reorderPoint  Int?
  
  // Unit of measure
  baseUnit      UnitOfMeasure @default(PIECE)
  weight        Decimal?      @db.Decimal(10, 3) // in kg
  dimensions    Json?         // { length, width, height, unit }
  
  // Relationships
  category      Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  company       Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  supplier      Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  variants      ProductVariant[]
  unitConversions UnitConversion[]
  
  // Timestamps
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  
  // Indexes
  @@index([baseSku])
  @@index([categoryId])
  @@index([companyId])
  @@index([supplierId])
  @@index([type])
  @@index([deletedAt])
}

// 3. PRODUCT VARIANTS
model ProductVariant {
  id          String  @id @default(uuid()) @db.Uuid
  productId   String  @db.Uuid
  sku         String  @unique // Full SKU with variant codes
  barcode     String? @unique
  name        String? // Optional override name
  
  // Variant-specific pricing
  costPrice   Decimal? @db.Decimal(12, 2)
  salePrice   Decimal? @db.Decimal(12, 2)
  
  // Physical properties
  weight      Decimal? @db.Decimal(10, 3)
  dimensions  Json?
  
  // Status
  isActive    Boolean @default(true)
  
  // Relationships
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributes  ProductVariantAttribute[]
  inventories WarehouseInventory[]
  batches     Batch[]
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  
  // Indexes
  @@index([productId])
  @@index([sku])
  @@index([isActive])
  @@index([deletedAt])
}

model ProductVariantAttribute {
  id        String  @id @default(uuid()) @db.Uuid
  variantId String  @db.Uuid
  attributeId String @db.Uuid
  valueId   String  @db.Uuid
  
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attribute ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value     ProductAttributeValue @relation(fields: [valueId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([variantId, attributeId])
  @@index([variantId])
  @@index([attributeId])
  @@index([valueId])
}

// 4. UNIT CONVERSION SYSTEM
model UnitConversion {
  id          String  @id @default(uuid()) @db.Uuid
  productId   String  @db.Uuid
  fromUnit    UnitOfMeasure
  toUnit      UnitOfMeasure
  conversionFactor Decimal @db.Decimal(10, 4) // e.g., 1 BOX = 12 PIECES => 12
  
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([productId, fromUnit, toUnit])
  @@index([productId])
  @@index([fromUnit])
  @@index([toUnit])
}

// 5. WAREHOUSE SYSTEM
model Warehouse {
  id          String        @id @default(uuid()) @db.Uuid
  code        String        @unique // e.g., "WH-001"
  name        String
  type        WarehouseType @default(MAIN)
  address     String?
  contact     String?
  phone       String?
  email       String?
  
  // Dimensions
  area        Decimal?      @db.Decimal(10, 2) // in square meters
  capacity    Decimal?      @db.Decimal(10, 2) // in cubic meters
  
  // Status
  isActive    Boolean       @default(true)
  
  // Relationships
  inventories WarehouseInventory[]
  locations   WarehouseLocation[]
  transfers   WarehouseTransfer[]
  
  // Timestamps
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  
  // Indexes
  @@index([code])
  @@index([type])
  @@index([isActive])
  @@index([deletedAt])
}

model WarehouseLocation {
  id          String  @id @default(uuid()) @db.Uuid
  warehouseId String  @db.Uuid
  code        String  // e.g., "A-01-02" (Aisle 01, Shelf 02)
  name        String? // e.g., "Main Storage Area"
  description String?
  
  // Location properties
  aisle       String?
  shelf       String?
  bin         String?
  row         String?
  column      String?
  
  // Capacity
  maxWeight   Decimal? @db.Decimal(10, 2)
  maxVolume   Decimal? @db.Decimal(10, 2)
  
  // Status
  isActive    Boolean @default(true)
  
  // Relationships
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  inventories WarehouseInventory[]
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  
  // Indexes
  @@unique([warehouseId, code])
  @@index([warehouseId])
  @@index([code])
  @@index([isActive])
  @@index([deletedAt])
}

// 6. WAREHOUSE INVENTORY (Stock per warehouse per variant)
model WarehouseInventory {
  id          String  @id @default(uuid()) @db.Uuid
  warehouseId String  @db.Uuid
  locationId  String? @db.Uuid
  variantId   String  @db.Uuid
  
  // Stock levels
  quantity    Int     @default(0)
  reserved    Int     @default(0)
  available   Int     @default(0) // Computed: quantity - reserved
  
  // Reorder info
  minLevel    Int?    @default(0)
  maxLevel    Int?
  reorderPoint Int?
  
  // Batch tracking
  batchId     String? @db.Uuid
  
  // Relationships
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  location    WarehouseLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  batch       Batch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  movements   StockMovement[]
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Indexes
  @@unique([warehouseId, variantId, batchId])
  @@index([warehouseId])
  @@index([variantId])
  @@index([locationId])
  @@index([batchId])
  @@index([quantity])
}

// 7. BATCH/LOT TRACKING
model Batch {
  id          String      @id @default(uuid()) @db.Uuid
  variantId   String      @db.Uuid
  batchNumber String      // e.g., "BATCH-2024-001"
  lotNumber   String?     // Manufacturer lot number
  
  // Production/Expiry
  productionDate DateTime?
  expiryDate     DateTime?
  status        BatchStatus @default(ACTIVE)
  
  // Quality
  qualityNotes  String?
  isQuarantined Boolean @default(false)
  
  // Relationships
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  inventories WarehouseInventory[]
  movements   StockMovement[]
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  
  // Indexes
  @@unique([variantId, batchNumber])
  @@index([variantId])
  @@index([batchNumber])
  @@index([lotNumber])
  @@index([expiryDate])
  @@index([status])
  @@index([deletedAt])
}

// 8. STOCK MOVEMENT LEDGER (Audit trail)
model StockMovement {
  id          String                   @id @default(uuid()) @db.Uuid
  inventoryId String                   @db.Uuid
  type        InventoryTransactionType
  quantity    Int                      // Positive for incoming, negative for outgoing
  reference   String?                  // e.g., "PO-001", "SO-001"
  referenceId String?                  @db.Uuid // Link to purchase/sale/transfer
  
  // Source/Destination
  fromWarehouseId String? @db.Uuid
  toWarehouseId   String? @db.Uuid
  fromLocationId  String? @db.Uuid
  toLocationId    String? @db.Uuid
  
  // Batch tracking
  batchId     String? @db.Uuid
  
  // User who performed the movement
  userId      String? @db.Uuid
  
  // Metadata
  notes       String?
  metadata    Json?   // Additional context
  
  // Relationships
  inventory   WarehouseInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  fromWarehouse Warehouse? @relation("StockMovementFrom", fields: [fromWarehouseId], references: [id], onDelete: SetNull)
  toWarehouse   Warehouse? @relation("StockMovementTo", fields: [toWarehouseId], references: [id], onDelete: SetNull)
  fromLocation  WarehouseLocation? @relation("StockMovementFromLocation", fields: [fromLocationId], references: [id], onDelete: SetNull)
  toLocation    WarehouseLocation? @relation("StockMovementToLocation", fields: [toLocationId], references: [id], onDelete: SetNull)
  batch       Batch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  user        User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // Timestamps
  createdAt   DateTime @default(now())
  
  // Indexes
  @@index([inventoryId, createdAt])
  @@index([type])
  @@index([reference])
  @@index([referenceId])
  @@index([userId])
  @@index([createdAt])
  @@index([fromWarehouseId, toWarehouseId])
}

// 9. WAREHOUSE TRANSFER
model WarehouseTransfer {
  id          String      @id @default(uuid()) @db.Uuid
  transferNumber String   @unique // e.g., "TRF-2024-001"
  
  fromWarehouseId String  @db.Uuid
  toWarehouseId   String  @db.Uuid
  
  status      String      @default("PENDING") // PENDING, IN_TRANSIT, COMPLETED, CANCELLED
  notes       String?
  
  // User who initiated
  createdByUserId String? @db.Uuid
  
  // Timestamps
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relationships
  fromWarehouse Warehouse @relation("TransferFrom", fields: [fromWarehouseId], references: [id], onDelete: Cascade)
  toWarehouse   Warehouse @relation("TransferTo", fields: [toWarehouseId], references: [id], onDelete: Cascade)
  createdByUser User?     @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  items         WarehouseTransferItem[]
  
  // Indexes
  @@index([transferNumber])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([status])
  @@index([createdAt])
}

model WarehouseTransferItem {
  id          String  @id @default(uuid()) @db.Uuid
  transferId  String  @db.Uuid
  variantId   String  @db.Uuid
  batchId     String? @db.Uuid
  
  quantity    Int
  quantityTransferred Int @default(0)
  
  // Relationships
  transfer    WarehouseTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  batch       Batch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([transferId])
  @@index([variantId])
  @@index([batchId])
}

// 10. EXISTING BUSINESS MODELS (Updated for compatibility)
model Company {
  id   String  @id @default(uuid()) @db.Uuid
  name String
  code String? @unique

  products Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([name])
  @@index([deletedAt])
}

model Category {
  id       String  @id @default(uuid()) @db.Uuid
  name     String
  slug     String
  parentId String? @db.Uuid

  parent   Category?  @relation("CategoryToChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryToChildren")

  products Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([parentId, slug])
  @@index([parentId])
  @@index([deletedAt])
}

model Supplier {
  id            String  @id @default(uuid()) @db.Uuid
  name          String
  email         String? @unique
  phone         String?
  address       String?
  contactPerson String?
  notes         String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}

// 11. ORDER SYSTEM (Enhanced)
model Order {
  id          String      @id @default(uuid()) @db.Uuid
  orderNumber String      @unique
  orderType   String      @default("SALE") // SALE, PURCHASE, TRANSFER
  status      OrderStatus @default(DRAFT)

  // Financials
  subtotal      Decimal @db.Decimal(12, 2)
  discountTotal Decimal @default(0) @db.Decimal(12, 2)
  taxTotal      Decimal @default(0) @db.Decimal(12, 2)
  shippingTotal Decimal @default(0) @db.Decimal(12, 2)
  total         Decimal @db.Decimal(12, 2)

  // References
  customerId    String? @db.Uuid
  supplierId    String? @db.Uuid
  warehouseId   String? @db.Uuid
  
  // Metadata
  notes           String?
  createdByUserId String? @db.Uuid

  // Relationships
  createdByUser User?       @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  customer      User?       @relation("OrderCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  supplier      Supplier?   @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  warehouse     Warehouse?  @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  items         OrderItem[]

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Indexes
  @@index([orderNumber])
  @@index([status])
  @@index([orderType])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([customerId])
  @@index([supplierId])
  @@index([warehouseId])
}

model OrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  orderId   String  @db.Uuid
  variantId String  @db.Uuid
  batchId   String? @db.Uuid

  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  lineTotal Decimal @db.Decimal(12, 2)

  // Relationships
  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  batch   Batch?          @relation(fields: [batchId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([variantId])
  @@index([batchId])
}

// 12. AUDIT LOG (Keep existing)
model AuditLog {
  id          String         @id @default(uuid()) @db.Uuid
  actorType   AuditActorType @default(USER)
  actorUserId String?        @db.Uuid
  action      AuditAction
  entityType  String?
  entityId    String?
  ip          String?
  userAgent   String?
  metadata    Json?
  
  // Request context
  requestId   String? @unique
  endpoint    String?
  method      String?
  statusCode  Int?
  
  actorUser User? @relation("AuditActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  
  createdAt DateTime @default(now())
  
  @@index([actorType, createdAt])
  @@index([actorUserId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([requestId])
}

// 13. AUTHENTICATION MODELS (Keep existing)
model RefreshToken {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid

  tokenHash String
  sessionId String
  userAgent String?
  ip        String?

  revokedAt    DateTime?
  replacedById String?   @db.Uuid
  expiresAt    DateTime

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBy RefreshToken?  @relation("RefreshTokenRotation", fields: [replacedById], references: [id], onDelete: SetNull)
  replaces   RefreshToken[] @relation("RefreshTokenRotation")

  createdAt DateTime @default(now())

  @@index([userId, sessionId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}