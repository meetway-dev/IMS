// ==============================================
// ENHANCED PRODUCTION-GRADE RBAC SCHEMA (CORRECTED)
// ==============================================
// This is a minimal enhancement that can be applied as a migration
// while keeping backward compatibility

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==============================================
// ENHANCED ENUMS
// ==============================================

enum UserStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
  PENDING
}

enum PermissionType {
  CRUD      // Standard CRUD operations (create, read, update, delete)
  PAGE      // Page-level access (dashboard.view, admin.panel.access)
  ACTION    // Action-level (approve, export, import, etc.)
  RESOURCE  // Resource-specific (users.update.own, users.update.all)
  SYSTEM    // System-level permissions (admin, super_admin)
}

enum PermissionEffect {
  ALLOW
  DENY
}

enum AuditAction {
  // User actions
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  USER_ROLE_ASSIGNED
  USER_ROLE_REVOKED
  USER_PERMISSION_ASSIGNED
  USER_PERMISSION_REVOKED
  USER_LOGIN
  USER_LOGOUT
  USER_PASSWORD_CHANGED
  
  // Role actions
  ROLE_CREATED
  ROLE_UPDATED
  ROLE_DELETED
  ROLE_PERMISSION_ASSIGNED
  ROLE_PERMISSION_REVOKED
  ROLE_CLONED
  
  // Permission actions
  PERMISSION_CREATED
  PERMISSION_UPDATED
  PERMISSION_DELETED
  
  // System actions
  SETTINGS_UPDATED
  AUDIT_LOG_VIEWED
  SYSTEM_BACKUP
  SYSTEM_RESTORE
  
  // Business actions
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_DELETED
  ORDER_CREATED
  ORDER_UPDATED
  ORDER_DELETED
  INVENTORY_ADJUSTED
}

enum AuditActorType {
  USER
  SYSTEM
  API
  BATCH
}

// Existing enums (preserved)
enum ProductType {
  SANITARY
  ELECTRICAL
}

enum UnitOfMeasure {
  PIECE
  BOX
  METER
}

enum InventoryTransactionType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  PAID
  CANCELLED
  REFUNDED
}

// ==============================================
// CORE RBAC MODELS (Enhanced)
// ==============================================

model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String     @unique
  passwordHash    String?
  googleSubject   String?    @unique
  name            String?
  status          UserStatus @default(ACTIVE)
  isEmailVerified Boolean    @default(false)
  lastLoginAt     DateTime?
  lastPasswordChangeAt DateTime?
  failedLoginAttempts Int    @default(0)
  lockedUntil     DateTime?

  // RBAC relationships
  roles           UserRole[]
  directPermissions UserPermission[]

  // Authentication
  refreshTokens   RefreshToken[]
  passwordResets  PasswordResetToken[]

  // Audit
  auditLogs       AuditLog[]           @relation("AuditActorUser")

  // Business relationships
  inventoryTransactions InventoryTransaction[]
  orders                Order[]

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  archivedAt      DateTime?

  // Indexes
  @@index([status])
  @@index([deletedAt])
  @@index([email])
  @@index([lastLoginAt])
  @@index([createdAt])
}

model Role {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique
  description String?
  isSystem    Boolean @default(false)
  isDefault   Boolean @default(false)
  priority    Int     @default(0) // Higher priority roles override lower ones
  parentRoleId String? @db.Uuid // For role hierarchy
  
  // Relationships
  users       UserRole[]
  permissions RolePermission[]
  parentRole  Role?    @relation("RoleHierarchy", fields: [parentRoleId], references: [id], onDelete: SetNull)
  childRoles  Role[]   @relation("RoleHierarchy")
  
  // Metadata
  createdByUserId String? @db.Uuid
  createdByUser   User?   @relation("RoleCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  
  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Indexes
  @@index([deletedAt])
  @@index([isSystem])
  @@index([isDefault])
  @@index([priority])
  @@index([parentRoleId])
  @@index([name])
}

model Permission {
  id          String         @id @default(uuid()) @db.Uuid
  key         String         @unique
  name        String
  description String?
  type        PermissionType @default(CRUD)
  effect      PermissionEffect @default(ALLOW)
  module      String         // e.g., "users", "products", "inventory"
  resource    String?        // e.g., "User", "Product", "Order"
  action      String?        // e.g., "create", "read", "update", "delete"
  scope       String?        // e.g., "own", "all", "team"
  
  // Relationships
  roles       RolePermission[]
  userPermissions UserPermission[]
  
  // Metadata
  isSystem    Boolean @default(false)
  version     Int     @default(1)
  
  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Constraints and Indexes
  @@unique([resource, action, scope])
  @@index([deletedAt])
  @@index([module])
  @@index([resource])
  @@index([action])
  @@index([type])
  @@index([key])
}

model UserRole {
  userId String @db.Uuid
  roleId String @db.Uuid
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  assignedByUserId String? @db.Uuid
  assignedByUser   User?   @relation("UserRoleAssigner", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  expiresAt        DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@id([userId, roleId])
  @@index([roleId])
  @@index([userId])
  @@index([expiresAt])
}

model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid
  
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  assignedByUserId String? @db.Uuid
  assignedByUser   User?   @relation("RolePermissionAssigner", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  expiresAt        DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@id([roleId, permissionId])
  @@index([permissionId])
  @@index([roleId])
  @@index([expiresAt])
}

model UserPermission {
  userId       String @db.Uuid
  permissionId String @db.Uuid
  priority     Int    @default(0) // Higher priority overrides lower
  effect       PermissionEffect @default(ALLOW)
  
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  assignedByUserId String? @db.Uuid
  assignedByUser   User?   @relation("UserPermissionAssigner", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  reason           String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime? // Optional expiration for temporary permissions
  
  @@id([userId, permissionId])
  @@index([permissionId])
  @@index([userId])
  @@index([priority])
  @@index([expiresAt])
  @@index([effect])
}

// ==============================================
// ENHANCED AUDIT LOGGING
// ==============================================

model AuditLog {
  id          String         @id @default(uuid()) @db.Uuid
  actorType   AuditActorType @default(USER)
  actorUserId String?        @db.Uuid
  action      AuditAction
  entityType  String?
  entityId    String?
  ip          String?
  userAgent   String?
  metadata    Json?
  
  // Request context
  requestId   String? @unique
  endpoint    String?
  method      String?
  statusCode  Int?
  
  actorUser User? @relation("AuditActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  
  createdAt DateTime @default(now())
  
  @@index([actorType, createdAt])
  @@index([actorUserId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([requestId])
}

// ==============================================
// EXISTING BUSINESS MODELS (Preserved exactly as in current schema)
// ==============================================

model Company {
  id   String  @id @default(uuid()) @db.Uuid
  name String
  code String? @unique

  products Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([name])
  @@index([deletedAt])
}

model Category {
  id       String  @id @default(uuid()) @db.Uuid
  name     String
  slug     String
  parentId String? @db.Uuid

  parent   Category?  @relation("CategoryToChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryToChildren")

  products Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([parentId, slug])
  @@index([parentId])
  @@index([deletedAt])
}

model Supplier {
  id            String  @id @default(uuid()) @db.Uuid
  name          String
  email         String? @unique
  phone         String?
  address       String?
  contactPerson String?
  notes         String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}

model Product {
  id            String        @id @default(uuid()) @db.Uuid
  name          String
  sku           String        @unique
  barcode       String?       @unique
  type          ProductType
  unit          UnitOfMeasure
  purchasePrice Decimal       @db.Decimal(12, 2)
  salePrice     Decimal       @db.Decimal(12, 2)
  minStockAlert Int           @default(0)

  categoryId String? @db.Uuid
  companyId  String? @db.Uuid

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  company  Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  variants  ProductVariant[]
  inventory InventoryItem?

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  deletedAt  DateTime?
  orderItems OrderItem[]

  @@index([type])
  @@index([categoryId])
  @@index([companyId])
  @@index([deletedAt])
}

model ProductVariant {
  id        String @id @default(uuid()) @db.Uuid
  productId String @db.Uuid

  size     String?
  color    String?
  material String?

  sku     String? @unique
  barcode String? @unique

  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory InventoryItem?

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  deletedAt  DateTime?
  orderItems OrderItem[]

  @@index([productId])
  @@index([deletedAt])
}

model InventoryItem {
  id        String  @id @default(uuid()) @db.Uuid
  productId String? @unique @db.Uuid
  variantId String? @unique @db.Uuid

  stockQuantity    Int @default(0)
  reservedQuantity Int @default(0)

  product Product?        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  transactions InventoryTransaction[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}

model InventoryTransaction {
  id              String                   @id @default(uuid()) @db.Uuid
  inventoryItemId String                   @db.Uuid
  type            InventoryTransactionType
  quantityDelta   Int
  reference       String?
  note            String?
  createdByUserId String?                  @db.Uuid

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  createdByUser User?         @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([inventoryItemId, createdAt])
  @@index([type])
  @@index([createdByUserId])
}

model Order {
  id          String      @id @default(uuid()) @db.Uuid
  orderNumber String      @unique
  status      OrderStatus @default(DRAFT)

  subtotal      Decimal @db.Decimal(12, 2)
  discountTotal Decimal @default(0) @db.Decimal(12, 2)
  taxTotal      Decimal @default(0) @db.Decimal(12, 2)
  total         Decimal @db.Decimal(12, 2)

  notes           String?
  createdByUserId String? @db.Uuid

  createdByUser User?       @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  items         OrderItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
}

model OrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  orderId   String  @db.Uuid
  productId String? @db.Uuid
  variantId String? @db.Uuid

  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  lineTotal Decimal @db.Decimal(12, 2)

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model RefreshToken {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid

  tokenHash String
  sessionId String
  userAgent String?
  ip        String?

  revokedAt    DateTime?
  replacedById String?   @db.Uuid
  expiresAt    DateTime

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBy RefreshToken?  @relation("RefreshTokenRotation", fields: [replacedById], references: [id], onDelete: SetNull)
  replaces   RefreshToken[] @relation("RefreshTokenRotation")

  createdAt DateTime @default(now())

  @@index([userId, sessionId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}