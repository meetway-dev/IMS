# Application
NODE_ENV=development
PORT=8080

# Database
# Docker: postgresql://ims:ims@db:5432/ims?schema=public
# Local:  postgresql://ims:ims@localhost:5432/ims?schema=public
DATABASE_URL="postgresql://ims:ims@localhost:5432/ims?schema=public"

# JWT (generate with: openssl rand -base64 32)
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_REFRESH_TTL_DAYS=30

# Password Hashing
PASSWORD_HASH_MEMORY_COST=65536
PASSWORD_HASH_TIME_COST=3
PASSWORD_HASH_PARALLELISM=1

# CORS
CORS_ORIGIN=http://localhost:3001
