# Production environment configuration
NODE_ENV=production
API_PORT=8080
FRONTEND_PORT=3001

POSTGRES_USER=ims
POSTGRES_PASSWORD=secure-password
POSTGRES_DB=ims
DATABASE_URL=postgresql://ims:secure-password@db:5432/ims?schema=public

JWT_ACCESS_SECRET=replace-with-a-secure-secret
JWT_REFRESH_SECRET=replace-with-a-secure-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

CORS_ORIGIN=https://your-production-domain.com
SWAGGER_PATH=docs

NEXT_PUBLIC_API_URL=https://your-production-domain.com/api/v1
NEXT_PUBLIC_APP_URL=https://your-production-domain.com
