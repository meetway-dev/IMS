# ============================================
# IMS - Inventory Management System
# Frontend Environment Variables
# ============================================
# Copy this file to .env.local and update with your values

# ============================================
# API Configuration
# ============================================
# For Docker: NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
# For Local: NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# ============================================
# Application Configuration
# ============================================
NEXT_PUBLIC_APP_NAME=IMS
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ============================================
# Environment
# ============================================
NODE_ENV=development

# ============================================
# Feature Flags
# ============================================
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=false

# ============================================
# Authentication Configuration
# ============================================
NEXT_PUBLIC_AUTH_ENABLED=true
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# ============================================
# Pagination Configuration
# ============================================
NEXT_PUBLIC_DEFAULT_PAGE_SIZE=20
NEXT_PUBLIC_MAX_PAGE_SIZE=100

# ============================================
# Upload Configuration
# ============================================
NEXT_PUBLIC_MAX_FILE_SIZE=5242880
NEXT_PUBLIC_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# ============================================
# Session Configuration
# ============================================
NEXT_PUBLIC_SESSION_TIMEOUT=1800000

# ============================================
# Theme Configuration
# ============================================
NEXT_PUBLIC_DEFAULT_THEME=light
NEXT_PUBLIC_ENABLE_DARK_MODE=true

# ============================================
# Date/Time Configuration
# ============================================
NEXT_PUBLIC_TIMEZONE=UTC
NEXT_PUBLIC_DATE_FORMAT=YYYY-MM-DD
NEXT_PUBLIC_TIME_FORMAT=HH:mm:ss

# ============================================
# Currency Configuration
# ============================================
NEXT_PUBLIC_CURRENCY=USD
NEXT_PUBLIC_CURRENCY_SYMBOL=$

# ============================================
# API Timeout Configuration
# ============================================
NEXT_PUBLIC_API_TIMEOUT=30000

# ============================================
# Development Configuration
# ============================================
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_LOG_LEVEL=info
