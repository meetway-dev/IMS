# Auto-detect text files and normalize line endings
* text=auto eol=lf

# Source code
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.prisma text eol=lf
*.css text eol=lf

# Shell
*.sh text eol=lf

# Docker
Dockerfile text eol=lf
docker-compose*.yml text eol=lf

# Lock files
package-lock.json text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.zip binary
*.ttf binary
*.woff binary
*.woff2 binary
